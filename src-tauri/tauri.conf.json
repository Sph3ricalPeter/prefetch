{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Prefetch",
  "version": "0.10.1",
  "identifier": "com.prefetch.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Prefetch",
        "width": 1600,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "theme": "Dark",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 18 }
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' https://www.gravatar.com https://avatars.githubusercontent.com https://secure.gravatar.com https://gitlab.com data: blob:; connect-src ipc: http://ipc.localhost https://www.gravatar.com"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW52cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxQzczQTYwQTlEQzNGMDcKUldRSFA5eXBZRHJIMGRPVDBKaG4rZFJXNzIrQ1MycHdGeFZLdW94Ky9YOFZaVDdXNUhKSXJuT1AK",
      "endpoints": [
        "https://github.com/Sph3ricalPeter/prefetch/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": ["nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
